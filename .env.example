# ╔══════════════════════════════════════════════════════════╗
# ║           LUCKY JAMBO — Environment Variables           ║
# ║  Copy this file to .env.local and fill in real values  ║
# ║  NEVER commit .env.local or any file with real keys    ║
# ╚══════════════════════════════════════════════════════════╝

# ── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Lucky Jambo
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── FAPSHI — COLLECTION SERVICE (Deposits) ───────────────
# NOTE: Fapshi requires SEPARATE services for collection vs payout.
# A service with payout enabled cannot collect payments.
# Create two separate services in your Fapshi dashboard.
FAPSHI_COLLECTION_API_USER=your_collection_service_api_user
FAPSHI_COLLECTION_API_KEY=your_collection_service_api_key

# ── FAPSHI — PAYOUT SERVICE (Withdrawals) ────────────────
FAPSHI_PAYOUT_API_USER=your_payout_service_api_user
FAPSHI_PAYOUT_API_KEY=your_payout_service_api_key

# Fapshi base URL — switch between sandbox and live
# Sandbox:  https://sandbox.fapshi.com
# Live:     https://live.fapshi.com
FAPSHI_BASE_URL=https://sandbox.fapshi.com

# ── GROQ (AI Engine) ──────────────────────────────────────
# console.groq.com → API Keys — SERVER-SIDE ONLY
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RESEND (Transactional Email) ──────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ── PLATFORM ─────────────────────────────────────────────
# These values are the source of truth in the Supabase `settings` table.
# Listed here for documentation only.
# PLATFORM_FEE_PERCENT=5
# MIN_DEPOSIT=50
# MAX_DEPOSIT=100000
# MIN_WITHDRAWAL=500
# MAX_WITHDRAWAL=100000
# AUTO_WITHDRAWAL_ENABLED=true
# AUTO_WITHDRAWAL_MAX_AMOUNT=20000
