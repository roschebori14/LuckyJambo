# ╔══════════════════════════════════════════════════════════╗
# ║           LUCKY JAMBO — Environment Variables           ║
# ║  Copy this file to .env.local and fill in real values  ║
# ║  NEVER commit .env.local or any file with real keys    ║
# ╚══════════════════════════════════════════════════════════╝


# ── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Lucky Jambo
NEXT_PUBLIC_APP_URL=https://yourdomain.com


# ── SUPABASE ──────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public keys (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret key — server-side only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT public key URL for token verification (optional)
SUPABASE_JWKS_URL=https://xxxxxxxxxxxx.supabase.co/auth/v1/jwks


# ── FAPSHI — COLLECTION (Deposits) ───────────────────────
# Found in: Fapshi Dashboard → API Keys → Collection
# Use sandbox keys during testing, live keys for production

FAPSHI_COLLECTION_API_KEY=your_collection_api_key
FAPSHI_COLLECTION_API_SECRET=your_collection_api_secret

# Webhook secret — generate a random string and set the same
# value in Fapshi Dashboard → Webhooks → Signing Secret
FAPSHI_WEBHOOK_SECRET=generate_a_long_random_string_here


# ── FAPSHI — PAYOUT (Withdrawals) ────────────────────────
# Found in: Fapshi Dashboard → API Keys → Payout
# Requires KYC approval before Fapshi activates payout access

FAPSHI_PAYOUT_API_KEY=your_payout_api_key
FAPSHI_PAYOUT_API_SECRET=your_payout_api_secret

# Fapshi base URL — switch between sandbox and live
# Sandbox:  https://sandbox.fapshi.com
# Live:     https://live.fapshi.com
FAPSHI_BASE_URL=https://sandbox.fapshi.com


# ── GROQ (AI Engine) ──────────────────────────────────────
# Found in: console.groq.com → API Keys
# Powers: player support chat, admin AI insights, username moderation
# SERVER-SIDE ONLY - never prefix with NEXT_PUBLIC_

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── RESEND (Transactional Email) ──────────────────────────
# Found in: resend.com → API Keys
# Used for auth emails (confirm signup, reset password)

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com


# ── PLATFORM SETTINGS ────────────────────────────────────
# These mirror the values in your Supabase `settings` table.
# The DB values are the source of truth at runtime — these
# are for local dev defaults and documentation only.

PLATFORM_FEE_PERCENT=5

MIN_DEPOSIT=50
MAX_DEPOSIT=100000

MIN_WITHDRAWAL=500
MAX_WITHDRAWAL=100000


# ── SUPABASE STORAGE BUCKETS ─────────────────────────────
# Create these buckets in Supabase Dashboard → Storage

SUPABASE_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_GAME_ASSETS=game-assets


# ── SECURITY ─────────────────────────────────────────────
# Rate limiting (applied in proxy.ts / API middleware)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60


# ── FEATURE FLAGS ────────────────────────────────────────
ENABLE_REALTIME=true
ENABLE_ANALYTICS=false
